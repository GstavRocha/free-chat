# Variaveis opcionais do frontend.
# No deploy padrao com Nginx + proxy interno, nenhuma delas e obrigatoria.

# Exemplo para apontar a API para um endereco externo:
# VITE_API_BASE_URL=https://api.exemplo.com/api

# Exemplo para apontar o WebSocket para um endereco externo:
# VITE_WS_BASE_URL=wss://api.exemplo.com/ws
