{
  "name": "free-chat",
  "version": "1.0.0",
  "description": "software desenvolvido como solução escolar",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "bash ./scripts/start-backend.sh",
    "start:server": "node server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "node --test tests/**/*.test.js",
    "migrate": "node src/database/run-migrations.js",
    "migrate:down": "node src/database/run-migrations.js down"
  },
  "keywords": [
    "SDD",
    "node.js",
    "Express.js"
  ],
  "author": "Gustavo Rocha",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^9.38.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "ws": "^8.20.0"
  }
}
